# Copy to assets/.env (or merge values into assets/.env) before release builds.
# Get OpenWeatherMap: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# India data.gov.in API key: https://data.gov.in/
AGMARKNET_API_KEY=

# Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional — defaults match current app if unset
API_BASE_URL=https://cropeye-mobilebackend.onrender.com
PLOT_LAYER_BASE_URL=https://cropeyeappapis.up.railway.app
HF_SCANNER_BASE_URL=https://sarveshaiml-fruit-grape-counter.hf.space
